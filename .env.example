# =============================================================================
# OpenClaw Platform - Environment Configuration (EXAMPLE)
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# =============================================================================

# --- AWS Account ---
AWS_ACCOUNT_ID=111122223333
AWS_REGION=us-west-2

# --- ECR ---
ECR_REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
ECR_REPO=${ECR_REGISTRY}/openclaw-provisioning

# --- Cognito ---
COGNITO_USER_POOL_ID=us-west-2_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# --- API Gateway ---
API_GATEWAY_ID=xxxxxxxxxx
API_GATEWAY_ENDPOINT=https://${API_GATEWAY_ID}.execute-api.${AWS_REGION}.amazonaws.com

# --- CloudFront ---
CLOUDFRONT_DOMAIN=dxxxexample.cloudfront.net
CLOUDFRONT_DISTRIBUTION_ID=EXXXXXXXXXXXXX

# --- IAM Roles ---
SHARED_BEDROCK_ROLE_ARN=arn:aws:iam::${AWS_ACCOUNT_ID}:role/openclaw-bedrock-shared

# --- EKS ---
EKS_CLUSTER_NAME=your-cluster-name

# --- Networking ---
PUBLIC_ALB_SUBNETS=subnet-xxxxxxxxxxxxxxxxx,subnet-xxxxxxxxxxxxxxxxx,subnet-xxxxxxxxxxxxxxxxx,subnet-xxxxxxxxxxxxxxxxx
PUBLIC_ALB_DNS=k8s-your-alb-dns.us-west-2.elb.amazonaws.com

# --- Build Server ---
BUILD_SERVER_IP=x.x.x.x
BUILD_SERVER=ec2-user@${BUILD_SERVER_IP}
SSH_KEY=${HOME}/.ssh/your-key.pem
REMOTE_REPO_PATH=~/openclaw-on-eks-graviton

# --- S3 ---
ARTIFACT_BUCKET=your-artifact-bucket-name
